{
  "name": "rn-compliance-analyst",
  "version": "1.0.0",
  "description": "MCP server for React Native Android/iOS policy compliance scanning and auto-fixing",
  "main": "dist/index.js",
  "bin": {
    "rn-compliance-analyst": "dist/index.js"
  },
  "files": [
    "dist",
    "policies"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest --runInBand",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "adm-zip": "^0.5.16",
    "semver": "^7.6.2",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.0.0",
    "@types/semver": "^7.5.8",
    "@types/xml2js": "^0.4.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ]
  }
}
